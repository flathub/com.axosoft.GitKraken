{
    "id": "com.axosoft.GitKraken",
    "runtime": "org.freedesktop.Sdk",
    "runtime-version": "25.08",
    "sdk": "org.freedesktop.Sdk",
    "base": "org.electronjs.Electron2.BaseApp",
    "base-version": "25.08",
    "command": "gitkraken",
    "tags": [
        "proprietary"
    ],
    "separate-locales": false,
    "finish-args": [
        "--require-version=0.11.1",
        "--share=ipc",
        "--socket=wayland",
        "--socket=fallback-x11",
        "--socket=pulseaudio",
        "--socket=ssh-auth",
        "--socket=pcsc",
        "--share=network",
        "--device=dri",
        "--filesystem=home",
        "--filesystem=/mnt",
        "--filesystem=/media",
        "--filesystem=/run/media",
        "--filesystem=xdg-run/gvfs",
        "--filesystem=xdg-run/gvfsd",
        "--talk-name=org.gtk.vfs.*",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.freedesktop.secrets",
        "--env=XCURSOR_PATH=run/host/user-share/icons:/run/host/share/icons"
    ],
    "modules": [
        {
            "name": "ImageMagick",
            "config-opts": [
                "--enable-static=no",
                "--with-modules",
                "--disable-docs",
                "--disable-deprecated",
                "--without-autotrace",
                "--without-bzlib",
                "--without-djvu",
                "--without-dps",
                "--without-fftw",
                "--without-fontconfig",
                "--without-fpx",
                "--without-freetype",
                "--without-gvc",
                "--without-jbig",
                "--without-jpeg",
                "--without-lcms",
                "--without-lzma",
                "--without-magick-plus-plus",
                "--without-openexr",
                "--without-openjp2",
                "--without-pango",
                "--without-raqm",
                "--without-tiff",
                "--without-webp",
                "--without-wmf",
                "--without-x",
                "--without-xml",
                "--without-zlib"
            ],
            "cleanup": [
                "*"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/ImageMagick/ImageMagick/archive/7.1.2-26.tar.gz",
                    "sha256": "d63594e334e1c410f600fb9370d78d49e4dc6f315722ca4ba083e864e5c354cb",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 1372,
                        "stable-only": true,
                        "url-template": "https://github.com/ImageMagick/ImageMagick/archive/${version}.tar.gz"
                    }
                }
            ]
        },
        {
            "name": "krb5",
            "subdir": "src",
            "buildsystem": "autotools",
            "config-opts": [
                "--localstatedir=/var/lib",
                "--sbindir=${FLATPAK_DEST}/bin",
                "--disable-static",
                "--disable-rpath"
            ],
            "cleanup": [
                "/bin",
                "/include",
                "/lib/pkgconfig",
                "/sbin",
                "/share/et",
                "/share/examples",
                "/share/man",
                "/var"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/krb5/krb5/archive/refs/tags/krb5-1.22.2-final.tar.gz",
                    "sha256": "289f5bb81d1f2f8d5eecebe56a056aeed95d35fd9bb4a7071c5dd7ad4b3fe888",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 13287,
                        "stable-only": true,
                        "url-template": "https://github.com/krb5/krb5/archive/refs/tags/krb5-$version.tar.gz"
                    }
                },
                {
                    "type": "shell",
                    "dest": "src",
                    "commands": [
                        "autoreconf -si"
                    ]
                }
            ]
        },
        {
            "name": "krb5-config",
            "buildsystem": "simple",
            "build-commands": [
                "install -Dm0644 krb5.conf -t /app/etc/"
            ],
            "sources": [
                {
                    "type": "file",
                    "path": "files/krb5/krb5.conf"
                }
            ]
        },
        {
            "name": "pcsc-lite",
            "buildsystem": "meson",
            "config-opts": [
                "-Dlibsystemd=false",
                "-Dlibudev=false",
                "-Dlibusb=false",
                "-Dpolkit=false",
                "-Dserial=false",
                "-Dsystemdunit=user",
                "-Dusb=false"
            ],
            "cleanup": [
                "/include",
                "/lib/pkgconfig"
            ],
            "post-install": [
                "rm /app/sbin/pcscd",
                "rmdir /app/sbin || true"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://salsa.debian.org/rousseau/PCSC/-/archive/2.5.1/PCSC-2.5.1.tar.bz2",
                    "sha256": "c8f11a6af2f46da55434ebb315ddc616c3e384bdee5e4f2e7a35081a0d978936",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 2611,
                        "stable-only": true,
                        "url-template": "https://salsa.debian.org/rousseau/PCSC/-/archive/$version/PCSC-$version.tar.bz2"
                    }
                }
            ]
        },
        {
            "name": "git-lfs",
            "buildsystem": "simple",
            "build-commands": [
                "PREFIX=${FLATPAK_DEST} ./install.sh"
            ],
            "sources": [
                {
                    "type": "archive",
                    "only-arches": [
                        "x86_64"
                    ],
                    "strip-components": 1,
                    "url": "https://github.com/git-lfs/git-lfs/releases/download/v3.7.1/git-lfs-linux-amd64-v3.7.1.tar.gz",
                    "sha256": "1c0b6ee5200ca708c5cebebb18fdeb0e1c98f1af5c1a9cba205a4c0ab5a5ec08",
                    "x-checker-data": {
                        "type": "json",
                        "url": "https://api.github.com/repos/git-lfs/git-lfs/releases/latest",
                        "url-query": ".assets[] | select(.name==\"git-lfs-linux-amd64-\" + $version + \".tar.gz\") | .browser_download_url",
                        "version-query": ".tag_name"
                    }
                },
                {
                    "type": "archive",
                    "only-arches": [
                        "aarch64"
                    ],
                    "strip-components": 1,
                    "url": "https://github.com/git-lfs/git-lfs/releases/download/v3.7.1/git-lfs-linux-arm64-v3.7.1.tar.gz",
                    "sha256": "73a9c90eeb4312133a63c3eaee0c38c019ea7bfa0953d174809d25b18588dd8d",
                    "x-checker-data": {
                        "type": "json",
                        "url": "https://api.github.com/repos/git-lfs/git-lfs/releases/latest",
                        "url-query": ".assets[] | select(.name==\"git-lfs-linux-arm64-\" + $version + \".tar.gz\") | .browser_download_url",
                        "version-query": ".tag_name"
                    }
                }
            ]
        },
        {
            "name": "gitkraken",
            "buildsystem": "simple",
            "build-commands": [
                ". ${FLATPAK_BUILDER_BUILDDIR}/build"
            ],
            "sources": [
                {
                    "type": "file",
                    "path": "apply_extra.sh"
                },
                {
                    "type": "file",
                    "path": "gitkraken-build.sh",
                    "dest-filename": "build"
                },
                {
                    "type": "file",
                    "path": "gitkraken.sh"
                },
                {
                    "type": "file",
                    "path": "com.axosoft.GitKraken.metainfo.xml"
                },
                {
                    "type": "file",
                    "only-arches": [
                        "x86_64"
                    ],
                    "dest-filename": "gitkraken.deb",
                    "url": "https://api.gitkraken.dev/releases/production/linux/x64/12.2.1/gitkraken-amd64.deb",
                    "sha256": "3cb7cbcbfecd35c9f8d6c2cfcf554ef0bf3f481df009e948b367720f3f27e2a3",
                    "x-checker-data": {
                        "type": "html",
                        "url": "https://help.gitkraken.com/gitkraken-desktop/current/",
                        "version-pattern": "Version ((?:\\d+\\.)?(?:\\d+\\.)?\\d+)",
                        "url-template": "https://api.gitkraken.dev/releases/production/linux/x64/$version/gitkraken-amd64.deb"
                    }
                },
                {
                    "type": "file",
                    "only-arches": [
                        "aarch64"
                    ],
                    "dest-filename": "gitkraken.deb",
                    "url": "https://api.gitkraken.dev/releases/production/linux/arm64/12.2.1/gitkraken-aarch64.deb",
                    "sha256": "34c77ccb077cbdadd6403aef654f2cb9d45ed37278fdf267fabb17c810871688",
                    "x-checker-data": {
                        "type": "html",
                        "url": "https://help.gitkraken.com/gitkraken-desktop/current/",
                        "version-pattern": "Version ((?:\\d+\\.)?(?:\\d+\\.)?\\d+)",
                        "url-template": "https://api.gitkraken.dev/releases/production/linux/arm64/$version/gitkraken-aarch64.deb"
                    }
                },
                {
                    "type": "extra-data",
                    "only-arches": [
                        "x86_64"
                    ],
                    "filename": "gitkraken.deb",
                    "url": "https://api.gitkraken.dev/releases/production/linux/x64/12.2.1/gitkraken-amd64.deb",
                    "sha256": "3cb7cbcbfecd35c9f8d6c2cfcf554ef0bf3f481df009e948b367720f3f27e2a3",
                    "size": 150590068,
                    "x-checker-data": {
                        "type": "html",
                        "url": "https://help.gitkraken.com/gitkraken-desktop/current/",
                        "version-pattern": "Version ((?:\\d+\\.)?(?:\\d+\\.)?\\d+)",
                        "url-template": "https://api.gitkraken.dev/releases/production/linux/x64/$version/gitkraken-amd64.deb",
                        "is-main-source": true
                    }
                },
                {
                    "type": "extra-data",
                    "only-arches": [
                        "aarch64"
                    ],
                    "filename": "gitkraken.deb",
                    "url": "https://api.gitkraken.dev/releases/production/linux/arm64/12.2.1/gitkraken-aarch64.deb",
                    "sha256": "34c77ccb077cbdadd6403aef654f2cb9d45ed37278fdf267fabb17c810871688",
                    "size": 158096072,
                    "x-checker-data": {
                        "type": "html",
                        "url": "https://help.gitkraken.com/gitkraken-desktop/current/",
                        "version-pattern": "Version ((?:\\d+\\.)?(?:\\d+\\.)?\\d+)",
                        "url-template": "https://api.gitkraken.dev/releases/production/linux/arm64/$version/gitkraken-aarch64.deb",
                        "is-main-source": true
                    }
                }
            ]
        }
    ]
}
